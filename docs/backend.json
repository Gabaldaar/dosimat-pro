
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an internal user or employee of the ChloriTrack Pro application, primarily for managing access roles and notification recipients.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the User entity." },
        "name": { "type": "string", "description": "The full name of the user." },
        "email": { "type": "string", "description": "The email address of the user.", "format": "email" },
        "role": { "type": "string", "description": "Admin or Employee." }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Gestión detallada de información de clientes y sus equipos de piscina.",
      "properties": {
        "id": { "type": "string" },
        "apellido": { "type": "string" },
        "nombre": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "localidad": { "type": "string" },
        "provincia": { "type": "string" },
        "pais": { "type": "string" },
        "mail": { "type": "string", "format": "email" },
        "cuit_dni": { "type": "string" },
        "observaciones": { "type": "string" },
        "equipoInstalado": {
          "type": "object",
          "properties": {
            "medidasPileta": { "type": "string" },
            "volumen": { "type": "number" },
            "dosisCloro": { "type": "string" },
            "cantidadBidones": { "type": "number" },
            "modeloEquipo": { "type": "string" },
            "enComodato": { "type": "boolean" }
          }
        },
        "esClienteReposicion": { "type": "boolean" },
        "saldoActual": { "type": "number" },
        "fechaUltimaReposicion": { "type": "string", "format": "date-time" },
        "creadoPor": { "type": "string" },
        "fechaCreacion": { "type": "string", "format": "date-time" },
        "ultimaModificacionPor": { "type": "string" },
        "fechaUltimaModificacion": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nombre", "apellido"]
    },
    "ProductOrService": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProductOrService",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "priceARS": { "type": "number" },
        "priceUSD": { "type": "number" },
        "isService": { "type": "boolean" }
      },
      "required": ["id", "name", "priceARS", "priceUSD", "isService"]
    },
    "FinancialAccount": {
      "title": "FinancialAccount",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "currency": { "type": "string" },
        "initialBalance": { "type": "number" }
      },
      "required": ["id", "name", "type", "currency", "initialBalance"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "financialAccountId": { "type": "string" },
        "clientId": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "date", "type", "amount", "currency", "financialAccountId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "Perfiles de usuario interno." } },
      { "path": "/clients/{clientId}", "definition": { "entityName": "Client", "schema": { "$ref": "#/backend/entities/Client" }, "description": "Base de datos maestra de clientes." } },
      { "path": "/products_services/{id}", "definition": { "entityName": "ProductOrService", "schema": { "$ref": "#/backend/entities/ProductOrService" } } },
      { "path": "/financial_accounts/{id}", "definition": { "entityName": "FinancialAccount", "schema": { "$ref": "#/backend/entities/FinancialAccount" } } },
      { "path": "/transactions/{id}", "definition": { "entityName": "Transaction", "schema": { "$ref": "#/backend/entities/Transaction" } } }
    ]
  }
}
