
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an application user with profile and roles.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Employee", "Communicator", "Replenisher", "Pending", "Blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Customer information and pool details.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "mail": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "saldoActual": { "type": "number" },
        "saldoUSD": { "type": "number" },
        "esClienteReposicion": { "type": "boolean" },
        "zonaId": { "type": "string" }
      }
    },
    "RouteSheet": {
      "title": "RouteSheet",
      "type": "object",
      "description": "Daily delivery plan for chemical replenishments.",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["planned", "active", "completed"] },
        "createdBy": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "clientId": { "type": "string" },
              "plannedChlorine": { "type": "number" },
              "realChlorine": { "type": "number" },
              "plannedAcid": { "type": "number" },
              "realAcid": { "type": "number" },
              "others": { "type": "string" },
              "cashCollected": { "type": "number" },
              "notes": { "type": "string" },
              "isDelivered": { "type": "boolean" },
              "processed": { "type": "boolean" }
            }
          }
        }
      }
    },
    "ProductService": {
      "title": "ProductService",
      "type": "object",
      "description": "Items in the catalog including parts and assemblies.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "priceARS": { "type": "number" },
        "priceUSD": { "type": "number" },
        "costARS": { "type": "number" },
        "costUSD": { "type": "number" },
        "trackStock": { "type": "boolean" },
        "stock": { "type": "number" },
        "supplier": { "type": "string", "description": "Name of the default supplier for this item." }
      }
    },
    "ProductionOrder": {
      "title": "ProductionOrder",
      "type": "object",
      "description": "A manufacturing order for a composite product.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "pending_purchase", "ready", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "purchaseQtys": { "type": "object", "description": "Manual purchase quantities defined for this order." }
      }
    },
    "Supplier": {
      "title": "Supplier",
      "type": "object",
      "description": "Entity providing materials or services.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "User profiles." }
      },
      {
        "path": "/clients/{clientId}",
        "definition": { "entityName": "Client", "description": "Customers." }
      },
      {
        "path": "/route_sheets/{sheetId}",
        "definition": { "entityName": "RouteSheet", "description": "Daily replenishment routes." }
      },
      {
        "path": "/products_services/{productId}",
        "definition": { "entityName": "ProductService", "description": "Inventory items." }
      },
      {
        "path": "/production_orders/{orderId}",
        "definition": { "entityName": "ProductionOrder", "description": "Production tracking." }
      },
      {
        "path": "/suppliers/{supplierId}",
        "definition": { "entityName": "Supplier", "description": "Managed list of providers." }
      }
    ]
  }
}
