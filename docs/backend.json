
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "fcmTokens": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Tokens de dispositivos registrados para notificaciones push."
        },
        "feesConfig": {
          "type": "object",
          "properties": {
            "valorCloro": { "type": "number" },
            "valorAcido": { "type": "number" },
            "valorHora": { "type": "number" },
            "valorKm": { "type": "number" },
            "baseFija": { "type": "number" }
          }
        }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Payout": {
      "title": "Payout",
      "type": "object",
      "description": "Registra una liquidación de haberes a un colaborador con capacidad de reversión.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "totalARS": { "type": "number" },
        "totalUSD": { "type": "number" },
        "exchangeRate": { "type": "number" },
        "currency": { "type": "string" },
        "financialAccountId": { "type": "string" },
        "transactionId": { "type": "string" },
        "itemIds": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Lista de IDs de ítems de ruta liquidados para permitir reversión (format: sheetId_idx)"
        },
        "routeItemsSnapshot": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sheetDate": { "type": "string" },
              "clientName": { "type": "string" },
              "cloro": { "type": "number" },
              "acido": { "type": "number" }
            }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "conceptId": { "type": "string" },
              "description": { "type": "string" },
              "amount": { "type": "number" },
              "currency": { "type": "string" },
              "qty": { "type": "number" },
              "notes": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "userId", "date", "financialAccountId"]
    },
    "PayoutConcept": {
      "title": "PayoutConcept",
      "type": "object",
      "description": "Conceptos preconfigurados para ítems adicionales en liquidaciones.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["fixed", "hourly", "km"] },
        "currency": { "type": "string", "enum": ["ARS", "USD"] },
        "defaultAmount": { "type": "number" }
      },
      "required": ["id", "name", "type"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User", "description": "Perfiles de usuario interno con configuración de honorarios y tokens de notificación." } },
      { "path": "/clients/{clientId}", "definition": { "entityName": "Customer", "description": "Cartera de clientes." } },
      { "path": "/route_sheets/{sheetId}", "definition": { "entityName": "RouteSheet", "description": "Planillas de entrega diaria." } },
      { "path": "/transactions/{txId}", "definition": { "entityName": "Transaction", "description": "Movimientos de caja y cuenta corriente." } },
      { "path": "/financial_accounts/{accountId}", "definition": { "entityName": "FinancialAccount", "description": "Cajas y bancos." } },
      { "path": "/products_services/{itemId}", "definition": { "entityName": "ProductService", "description": "Catálogo de productos e insumos." } },
      { "path": "/production_orders/{orderId}", "definition": { "entityName": "ProductionOrder", "description": "Planes de armado." } },
      { "path": "/purchase_orders/{poId}", "definition": { "entityName": "PurchaseOrder", "description": "Órdenes de compra a proveedores." } },
      { "path": "/suppliers/{supId}", "definition": { "entityName": "Supplier", "description": "Registro de proveedores." } },
      { "path": "/payouts/{payoutId}", "definition": { "entityName": "Payout", "description": "Liquidaciones de sueldos y honorarios." } },
      { "path": "/payout_concepts/{conceptId}", "definition": { "entityName": "PayoutConcept", "description": "Conceptos maestros de liquidación." } },
      { "path": "/zones/{zoneId}", "definition": { "entityName": "Zone", "description": "Zonas geográficas." } },
      { "path": "/email_templates/{tId}", "definition": { "entityName": "Template", "description": "Plantillas de correo." } },
      { "path": "/whatsapp_templates/{tId}", "definition": { "entityName": "Template", "description": "Plantillas de WhatsApp." } },
      { "path": "/product_categories/{catId}", "definition": { "entityName": "Category", "description": "Categorías de productos." } },
      { "path": "/expense_categories/{catId}", "definition": { "entityName": "Category", "description": "Categorías de gastos." } },
      { "path": "/purchases/{purchaseId}", "definition": { "entityName": "Purchase", "description": "Registros históricos de compras a proveedores." } }
    ]
  }
}
