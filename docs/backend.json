
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an application user with profile and roles.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Customer information and pool details.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "mail": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "saldoActual": { "type": "number" },
        "saldoUSD": { "type": "number" }
      }
    },
    "ProductService": {
      "title": "ProductService",
      "type": "object",
      "description": "Items in the catalog including parts and assemblies.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "priceARS": { "type": "number", "description": "Venta ARS" },
        "priceUSD": { "type": "number", "description": "Venta USD" },
        "costARS": { "type": "number", "description": "Costo calculado ARS" },
        "costUSD": { "type": "number", "description": "Costo calculado USD" },
        "laborCostARS": { "type": "number", "description": "Mano de obra ARS" },
        "laborCostUSD": { "type": "number", "description": "Mano de obra USD" },
        "isService": { "type": "boolean" },
        "isCompuesto": { "type": "boolean" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        }
      }
    },
    "ProductCategory": {
      "title": "ProductCategory",
      "type": "object",
      "description": "Categories for catalog items.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "EmailTemplate": {
      "title": "EmailTemplate",
      "type": "object",
      "description": "Templates for email notifications.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "bcc": { "type": "string", "description": "Blind Carbon Copy emails separated by semicolon." }
      }
    },
    "WhatsAppTemplate": {
      "title": "WhatsAppTemplate",
      "type": "object",
      "description": "Templates for WhatsApp messages.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "body": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "User profiles." }
      },
      {
        "path": "/user_roles/{userId}",
        "definition": { "entityName": "User", "description": "Security roles." }
      },
      {
        "path": "/clients/{clientId}",
        "definition": { "entityName": "Client", "description": "Customers." }
      },
      {
        "path": "/products_services/{productId}",
        "definition": { "entityName": "ProductService", "description": "Catalog items." }
      },
      {
        "path": "/product_categories/{categoryId}",
        "definition": { "entityName": "ProductCategory", "description": "Item categories." }
      },
      {
        "path": "/zones/{zoneId}",
        "definition": { "entityName": "Zone", "description": "Geographic zones." }
      },
      {
        "path": "/financial_accounts/{accountId}",
        "definition": { "entityName": "FinancialAccount", "description": "Cash boxes." }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": { "entityName": "Transaction", "description": "Financial records." }
      },
      {
        "path": "/email_templates/{templateId}",
        "definition": { "entityName": "EmailTemplate", "description": "Message templates." }
      },
      {
        "path": "/whatsapp_templates/{templateId}",
        "definition": { "entityName": "WhatsAppTemplate", "description": "WhatsApp message templates." }
      }
    ]
  }
}
