
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an application user with profile and roles.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Customer information and pool details.",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "mail": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "saldoActual": { "type": "number" },
        "saldoUSD": { "type": "number" }
      }
    },
    "ProductService": {
      "title": "ProductService",
      "type": "object",
      "description": "Items in the catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "priceARS": { "type": "number" },
        "priceUSD": { "type": "number" },
        "isService": { "type": "boolean" }
      }
    },
    "EmailTemplate": {
      "title": "EmailTemplate",
      "type": "object",
      "description": "Templates for email notifications.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "bcc": { "type": "string", "description": "Blind Carbon Copy emails separated by semicolon." }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "User profiles." }
      },
      {
        "path": "/user_roles/{userId}",
        "definition": { "entityName": "User", "description": "Security roles." }
      },
      {
        "path": "/clients/{clientId}",
        "definition": { "entityName": "Client", "description": "Customers." }
      },
      {
        "path": "/products_services/{productId}",
        "definition": { "entityName": "ProductService", "description": "Catalog items." }
      },
      {
        "path": "/zones/{zoneId}",
        "definition": { "entityName": "Zone", "description": "Geographic zones." }
      },
      {
        "path": "/financial_accounts/{accountId}",
        "definition": { "entityName": "FinancialAccount", "description": "Cash boxes." }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": { "entityName": "Transaction", "description": "Financial records." }
      },
      {
        "path": "/email_templates/{templateId}",
        "definition": { "entityName": "EmailTemplate", "description": "Message templates." }
      }
    ]
  }
}
