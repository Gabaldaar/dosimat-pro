/**
 * ChloriTrack Pro - Security Rules Configuration
 * 
 * Core Philosophy:
 * This ruleset enforces a strict Role-Based Access Control (RBAC) model leveraging "Database-wide Access Control" (DBAC).
 * Authorization is decoupled from the document hierarchy, using dedicated marker collections (/roles_admin and /roles_operator) 
 * to determine user privileges. This approach ensures high performance by avoiding recursive get() calls.
 * 
 * Data Structure:
 * - /users/{userId}: Private user profiles, restricted to the account owner.
 * - /roles_admin/{userId} & /roles_operator/{userId}: System-level role markers used for permission checks.
 * - /clients, /products, /services, /financial_accounts, /transactions: Top-level collections for shared business data.
 * 
 * Key Security Decisions:
 * 1. Role Verification: Permissions are granted based on the existence of a document in specific role collections.
 * 2. Immutable Audit Trails: Transactions and critical ownership fields (creadoPorId) are protected from modification after creation.
 * 3. Administrative Oversight: Destructive operations (deletes) and master data management (products/services) are restricted to the Admin role.
 * 4. Structural Segregation: Business data is maintained in flat, top-level collections where all documents share the same security posture.
 * 
 * Prototyping Mode:
 * These rules strictly enforce "Who" can access data (Authorization) and "Relational Integrity" (ownership links), 
 * but do not enforce the exact "Shape" or "Data Types" of the content to allow for rapid frontend iteration.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user is the owner of the document based on the path ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user has the 'admin' role via DBAC marker collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Checks if the user has the 'operator' role via DBAC marker collection. */
    function isOperator() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_operator/$(request.auth.uid));
    }

    /** Helper to check if user has any authorized system role. */
    function isAuthorized() {
      return isAdmin() || isOperator();
    }

    /** Validates that a field is not being changed during an update. */
    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Restricted to the user themselves.
     * @path /users/{userId}
     * @allow (get, create, update) if the authenticated user's UID matches the {userId} path variable.
     * @deny (list) to prevent user enumeration.
     * @principle Path-based ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Role marker collections. Used to identify Admin/Operator status.
     * @path /roles_admin/{userId} or /roles_operator/{userId}
     * @allow (get) for any signed-in user to verify roles; (write) for Admins only.
     * @deny (list) to prevent permission discovery.
     * @principle Existence-based Role-Based Access Control (DBAC).
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }
    match /roles_operator/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Management of customer records including pool specs and financial balances.
     * @path /clients/{clientId}
     * @allow (read, create, update) for Admins and Operators; (delete) for Admins only.
     * @deny (write) if the 'creadoPorId' is missing or mismatched on creation.
     * @principle Role-based shared access with creation audit validation.
     */
    match /clients/{clientId} {
      allow get, list: if isAuthorized();
      allow create: if isAuthorized() && request.resource.data.creadoPorId == request.auth.uid;
      allow update: if isAuthorized() && isUnchanged('creadoPorId');
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Product and Service definitions.
     * @path /products/{productId} or /services/{serviceId}
     * @allow (read) for all staff; (write) restricted to Admins.
     * @deny (write) for Operators.
     * @principle Read-only for general staff, managed by administrators.
     */
    match /products/{productId} {
      allow get, list: if isAuthorized();
      allow create, update, delete: if isAdmin();
    }
    match /services/{serviceId} {
      allow get, list: if isAuthorized();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Financial accounts tracking cash, banks, etc.
     * @path /financial_accounts/{accountId}
     * @allow (read, update) for all staff; (create, delete) for Admins.
     * @deny (create/delete) for Operators.
     * @principle Shared visibility with administrative structure control.
     */
    match /financial_accounts/{accountId} {
      allow get, list: if isAuthorized();
      allow update: if isAuthorized() && resource != null;
      allow create, delete: if isAdmin();
    }

    /**
     * @description Immutable audit trail of all business transactions.
     * @path /transactions/{transactionId}
     * @allow (read, create) for all staff.
     * @deny (update, delete) as transactions must be immutable for accounting integrity.
     * @principle Append-only historical log.
     */
    match /transactions/{transactionId} {
      allow get, list: if isAuthorized();
      allow create: if isAuthorized() && request.resource.data.creadoPorId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}