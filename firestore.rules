
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica si el usuario tiene un rol específico
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Define si el usuario es personal interno (Admin o Empleado)
    function isStaff() {
      return hasRole('Admin') || hasRole('Employee');
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || hasRole('Admin'));
    }

    // Reglas universales de lectura para usuarios autenticados
    // Esto previene errores de "Insufficient Permissions" durante la carga inicial del perfil
    match /{collection}/{docId} {
      allow read: if isSignedIn();
    }

    // Reglas de escritura restringidas por Rol
    match /clients/{docId} { allow write: if isStaff() || hasRole('Communicator'); }
    match /route_sheets/{docId} { allow write: if isStaff() || hasRole('Communicator') || hasRole('Replenisher'); }
    match /financial_accounts/{docId} { allow write: if isStaff(); }
    match /transactions/{docId} { allow write: if isStaff(); }
    match /products_services/{docId} { allow write: if isStaff(); }
    match /production_orders/{docId} { allow write: if isStaff(); }
    match /purchase_orders/{docId} { allow write: if isStaff(); }
    match /suppliers/{docId} { allow write: if isStaff(); }
    match /payouts/{docId} { allow write: if isStaff(); }
    match /payout_concepts/{docId} { allow write: if isStaff(); }
    match /zones/{docId} { allow write: if isStaff() || hasRole('Communicator'); }
    match /product_categories/{docId} { allow write: if isStaff(); }
    match /expense_categories/{docId} { allow write: if isStaff(); }
    match /email_templates/{docId} { allow write: if isStaff() || hasRole('Communicator'); }
    match /whatsapp_templates/{docId} { allow write: if isStaff() || hasRole('Communicator'); }
    match /purchases/{docId} { allow write: if isStaff(); }
    match /user_roles/{docId} { allow write: if hasRole('Admin'); }
  }
}
