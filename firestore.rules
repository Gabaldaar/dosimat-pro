rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función: El usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función: El usuario tiene rol de Administrador (con verificación de existencia)
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Perfiles de usuario
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Clientes
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    // Catálogo
    match /products_services/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Cuentas Financieras
    match /financial_accounts/{id} {
      allow read, write: if isAuthenticated();
    }

    // Transacciones - Acceso explícito para lectura y creación
    match /transactions/{txId} {
      allow get, list, create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Categorías y otros
    match /expense_categories/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /notification_rules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}