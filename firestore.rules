rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función: El usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función: El usuario tiene rol de Administrador en su perfil
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Perfiles de usuario: Lectura para todos los autenticados, escritura solo dueño o admin
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Clientes: Acceso total para personal autenticado
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
      match /pools/{poolId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Catálogo: Lectura para todos, escritura solo Admin
    match /products_services/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Cuentas Financieras: Lectura para todos, escritura para Admin o actualizaciones de saldo
    match /financial_accounts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Simplificado para permitir actualizaciones de saldo desde operaciones
    }

    // Categorías de Gasto: Lectura para todos, escritura solo Admin
    match /expense_categories/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Transacciones: Lectura y creación para todos los autenticados, edición/borrado solo Admin
    match /transactions/{txId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Notificaciones y reglas
    match /notification_rules/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}