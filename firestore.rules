rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DOSIMAT PRO - REGLAS DE SEGURIDAD OPTIMIZADAS
     */

    // --- FUNCIONES HELPER ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRoleData() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) &&
             getUserRoleData().roleIds.hasAny(roles);
    }

    function isAdmin() {
      return hasAnyRole(['admin', 'Admin', 'ADMIN']);
    }

    function isStaff() {
      return hasAnyRole(['staff', 'Staff', 'admin', 'Admin', 'ADMIN', 'Employee', 'STAFF']);
    }

    // --- REGLAS DE COLECCIÓN ---

    match /users/{userId} {
      allow get, create: if isOwner(userId);
      allow list: if isStaff();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /user_roles/{userId} {
      // Permitimos que el propietario cree y actualice su propio documento de roles.
      // Esto es crucial para el arranque del primer administrador y para que el usuario
      // pueda gestionar su propia identidad de seguridad si tiene los permisos de UI.
      allow get, create, update: if isOwner(userId);
      allow list: if isStaff();
      allow delete: if isAdmin();
    }

    match /zones/{zoneId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isStaff();
    }

    match /clients/{clientId} {
      allow get, list, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /products_services/{productId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /financial_accounts/{accountId} {
      allow get, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /expense_categories/{categoryId} {
      allow get, list: if isStaff();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow get, list, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /email_templates/{templateId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isAdmin();
    }
  }
}