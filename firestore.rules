rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función básica: el usuario está logueado en Firebase Auth
    function isAnyUser() {
      return request.auth != null;
    }

    // Función: el usuario es administrador (requiere perfil con rol Admin)
    function isAdmin() {
      return isAnyUser() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read: if isAnyUser();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Reglas para Roles Administrativos (Colección explícita de seguridad)
    match /admin_roles/{adminUid} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    // Reglas para Clientes
    match /clients/{clientId} {
      allow read, write: if isAnyUser();
      match /pools/{poolId} {
        allow read, write: if isAnyUser();
      }
    }

    // Reglas para Catálogo (Lectura todos, Escritura solo Admin)
    match /products_services/{id} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    // Reglas para Finanzas y Cuentas
    match /financial_accounts/{id} {
      allow read: if isAnyUser();
      allow write: if isAdmin() || (isAnyUser() && request.method == 'update'); 
    }

    match /expense_categories/{id} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    // Reglas para Transacciones
    match /transactions/{id} {
      allow read, create: if isAnyUser();
      allow update, delete: if isAdmin();
    }

    // Reglas para Notificaciones
    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if isAdmin();
    }
    
    match /notification_rules/{id} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }
  }
}