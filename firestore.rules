rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitimos lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
    // para facilitar el prototipado y el acceso desde diferentes dispositivos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // El catálogo de productos puede ser leído por cualquiera (incluso sin login)
    match /products_services/{id} {
      allow read: if true;
    }
  }
}