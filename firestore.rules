rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas simplificadas para garantizar acceso a usuarios autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas específicas por colección para mayor claridad en los logs de auditoría
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }
    
    match /products_services/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /financial_accounts/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /expense_categories/{id} {
      allow read, write: if request.auth != null;
    }
  }
}