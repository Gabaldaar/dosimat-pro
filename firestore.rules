
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica si el usuario tiene un rol específico
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Define si el usuario es personal con permisos de gestión total (Admin o Socio/Employee)
    function isManagement() {
      return hasRole('Admin') || hasRole('Employee');
    }

    // Define si el usuario es personal autorizado para ver información (Staff extendido)
    function isStaff() {
      return isManagement() || hasRole('Collaborator') || hasRole('Communicator') || hasRole('Replenisher');
    }

    // Reglas para perfiles de usuario
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || hasRole('Admin'));
    }

    // Reglas universales de lectura para personal autorizado
    match /{collection}/{docId} {
      allow read: if isStaff();
    }

    // Reglas de escritura específicas
    // Clientes: Admin, Socio, Comunicador y el nuevo Colaborador pueden editar
    match /clients/{docId} { 
      allow write: if isManagement() || hasRole('Collaborator') || hasRole('Communicator'); 
    }
    
    // Hojas de Ruta: Admin, Socio, Comunicador y Repositor
    match /route_sheets/{docId} { 
      allow write: if isManagement() || hasRole('Communicator') || hasRole('Replenisher'); 
    }

    // Finanzas y Operaciones: Solo Admin y Socio (Management)
    match /financial_accounts/{docId} { allow write: if isManagement(); }
    match /transactions/{docId} { allow write: if isManagement(); }
    match /payouts/{docId} { allow write: if isManagement(); }
    match /payout_concepts/{docId} { allow write: if isManagement(); }
    
    // Configuración y Catálogo: Solo Admin y Socio
    match /products_services/{docId} { allow write: if isManagement(); }
    match /production_orders/{docId} { allow write: if isManagement(); }
    match /purchase_orders/{docId} { allow write: if isManagement(); }
    match /suppliers/{docId} { allow write: if isManagement(); }
    match /zones/{docId} { allow write: if isManagement() || hasRole('Communicator'); }
    match /product_categories/{docId} { allow write: if isManagement(); }
    match /expense_categories/{docId} { allow write: if isManagement(); }
    match /email_templates/{docId} { allow write: if isManagement() || hasRole('Communicator'); }
    match /whatsapp_templates/{docId} { allow write: if isManagement() || hasRole('Communicator'); }
    match /purchases/{docId} { allow write: if isManagement(); }
    
    match /user_roles/{docId} { allow write: if hasRole('Admin'); }
  }
}
